# =========================
# plastomes_assembly config
# =========================

# -------------------------
# Input data
# -------------------------
RAW_DIR="data/raw"

# -------------------------
# Output base directories
# -------------------------
RESULTS_DIR="results"
LOG_DIR="logs"

# Derived (default conventions used by scripts)
# You can override if needed.
TRIMMED_PAIRED_DIR="results/02_trimming/paired"

# -------------------------
# Resources
# -------------------------
THREADS=8

# -------------------------
# Tools
# (leave as command names if available in PATH)
# -------------------------
FASTQC_BIN="fastqc"
PYTHON_BIN="python3"

# -------------------------
# Trimming (Trimmomatic)
# Set absolute paths locally in config/config.env
# -------------------------
TRIMMOMATIC_JAR=""
ADAPTERS_FA=""

# -------------------------
# GetOrganelle
# -------------------------
GETORGANELLE_BIN="get_organelle_from_reads.py"
GETORGANELLE_ENV_NAME="getorganelle"   # used only if running with --conda
GETORGANELLE_MODE="embplant_pt"
ROUNDS=10
KSET="21,45,65,85,105"
